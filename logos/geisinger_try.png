        var postUrl = "/api/Search/AutoComplete";

        function SearchText() {
            $("#gn-header-navigation-searchtext").autocomplete({
                source: function(request, response) {
                    $.ajax({
                        type: "POST",
                        contentType: "application/json; charset=utf-8",
                        url: postUrl,
                        data: "{'term':'" + document.getElementById('gn-header-navigation-searchtext').value + "'}",
                        dataType: "json",
                        success: function(data) {
                            response($.map(data,
                                function(item) {
                                    return { label: item, value: item };
                                }));
                        },
                        error: function(result) {
                            return;
                        }
                    });
                },
                select: function(event, ui) {
                    $("#gn-header-navigation-searchtext").val(ui.item.label);
                    return true;


                }
            });
        }
    </script>
