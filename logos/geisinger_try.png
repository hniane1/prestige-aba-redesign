    <script type="text/javascript">

        document.addEventListener('DOMContentLoaded',
            function() {
                SearchText();

            });

        var postUrl = "/api/Search/AutoComplete";

        function SearchText() {
            $("#headersearchtext").autocomplete({
                source: function(request, response) {
                    $.ajax({
                        type: "POST",
                        contentType: "application/json; charset=utf-8",
                        url: postUrl,
                        data: "{'term':'" + document.getElementById('headersearchtext').value + "'}",
                        dataType: "json",
                        success: function(data) {
                            response($.map(data,
                                function(item) {
                                    return { label: item, value: item };
                                }));
                        },
                        error: function(result) {
                            return;
                        }
                    });
                },
                select: function(event, ui) {
                    $("#searchtext").val(ui.item.label);
                    return true;


                }
            });
        }
    </script>
        <div class="o-search">
            <form class="o-search__form" action="/sites/search-result">
                <input id="headersearchtext" role="searchbox" name="q" class="o-search__input" type="text" placeholder="Search...">
                <button type="submit" class="o-search__btn" title="search submit">
                    <svg class="o-search__icon" viewbox="0 0 24 24">
                        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z">
                        </path>
                    </svg>
                </button>
            </form>
        </div>

        </div>
    </div>

