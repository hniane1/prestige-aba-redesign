<!-- Prevent Escape key from dismissing banner  -->
<script type="text/javascript" >
window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' || event.keyCode === 27) {
        // OneTrust often uses this specific ID for the banner container
        const banner = document.getElementById('onetrust-banner-sdk');
        
        // If the banner exists and is visible, block the Escape key
        if (banner) {
            event.stopImmediatePropagation();
            event.preventDefault();
        }
    }
}, true); // The 'true' (capture phase) is critical to intercept the event before OneTrust sees it
</script>

    

